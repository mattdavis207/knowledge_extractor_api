APP_NAME=Knowledge Extractor API
APP_ENV=local
API_V1_PREFIX=/api/v1
HTTP_TIMEOUT_SECONDS=10
CORS_ALLOW_ORIGINS=*

# Optional: GitHub personal access token for authenticated repository API calls.
GITHUB_PERSONAL_ACCESS_TOKEN=

# Required for TradingView Data API endpoints.
TRADINGVIEW_RAPIDAPI_KEY=
TRADINGVIEW_RAPIDAPI_HOST=tradingview-data1.p.rapidapi.com
TRADINGVIEW_API_BASE_URL=https://tradingview-data1.p.rapidapi.com
TRADINGVIEW_CURRENCY_PAIRS_CACHE_TTL_SECONDS=86400
TRADINGVIEW_BULK_PAGE_DELAY_SECONDS=1.0
TRADINGVIEW_PRICE_REQUEST_DELAY_SECONDS=1.0
TRADINGVIEW_PRICE_REQUEST_MAX_RETRIES=2
TRADINGVIEW_PRICE_REQUEST_RETRY_DELAY_SECONDS=10.0
TRADINGVIEW_PRICE_REQUEST_MAX_CANDLES_PER_REQUEST=10000
ANALYSIS_WEBHOOK_URL=https://mattdavis207.app.n8n.cloud/webhook/2b0a8594-f02c-4528-a30b-1971fa379fd9
ANALYSIS_WEBHOOK_TEST_URL=https://mattdavis207.app.n8n.cloud/webhook-test/2b0a8594-f02c-4528-a30b-1971fa379fd9

# Example external API used by app/api/v1/endpoints/example.py
JSONPLACEHOLDER_BASE_URL=https://jsonplaceholder.typicode.com

# Optional: required on many cloud hosts because YouTube blocks cloud provider IPs.
# Prefer Webshare residential proxies.
YOUTUBE_WEBSHARE_PROXY_USERNAME=
YOUTUBE_WEBSHARE_PROXY_PASSWORD=
YOUTUBE_WEBSHARE_PROXY_LOCATIONS=us

# Alternative generic proxy settings.
YOUTUBE_HTTP_PROXY_URL=
YOUTUBE_HTTPS_PROXY_URL=
